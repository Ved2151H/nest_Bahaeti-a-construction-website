# GEMINI_API_KEY: Required for Gemini AI API calls in the AI chat drawer.
#
# Local dev: copy this file to `.env`, paste a real key from
# https://aistudio.google.com/apikey , then restart `npm run dev`.
# (Vite reads `.env` and injects this into the client build — do not commit `.env`.)
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
